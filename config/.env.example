# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=nexauth-super-secret-change-this
JWT_EXPIRES_IN=7d

# AI Engine
RISK_THRESHOLD_BLOCK=80
RISK_THRESHOLD_ALERT=95
MAX_ATTEMPTS_PER_MINUTE=100

# Cloudflare Tunnel
TUNNEL_URL=https://your-tunnel-url.trycloudflare.com

# Dashboard
DASHBOARD_PORT=3000
REACT_APP_API_URL=http://localhost:4000
