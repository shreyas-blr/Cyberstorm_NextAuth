# Dependencies
node_modules/
dashboard/node_modules/
server/node_modules/

# SQLite database files (runtime data — never commit)
server/database/*.db
server/database/*.db-shm
server/database/*.db-wal

# Production builds
dashboard/build/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories
.DS_Store
Thumbs.db
.idea/

# React CRA cache
dashboard/.eslintcache
